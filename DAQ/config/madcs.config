MADCS:
  ID: 1              # Module System ID
  CH: 4              # Number of Channels
  NABLED: 1          # 1: Enable, 0: Disable
  
   --- Channel Mapping ---
  ID: [1, 2, 3, 4]   # Channel ID
  ID: [1, 2, 3, 4]   # Physics ID
  OL: 0              # Polarity: 0 (Neg), 1 (Pos)
  
   --- Trigger Settings ---
  RGON: 1            # Global Trigger: Normal(1), Random(2), External(4)
  TRG: 1             # Random trigger rate (1 / 1 ms)
  SC: 1              # Prescale
  LT: "1+2+3+4"      # Trigger Lookup Table logic
  M: 1               # Self-trigger Mode: Count(1), Width(2), Sum(4)
  
   --- Acquisition Parameters ---
  ACOFF: 3900        # Pedestal offset
  LY: 500            # Signal delay (ns)
  HR: 85             # Threshold (ADC counts)
  W: 64              # Coincidence Width
  
   --- Extended Record Length ---
   Window = 128 * 256 ns = 32,768 ns (approx. 32.7 us)
  L: 256             

   --- Pulse Count Settings ---
  CT: 1              # Pulse Count Threshold
  CI: 1000           # Pulse Count Interval

# ==============================================================================
# CUPDAQ YAML Configuration Tutorial
# ==============================================================================
# 1. INDENTATION: Use 'Spaces' only. Never use Tabs! (Standard is 2 spaces).
# 2. COLON (:): There MUST be a space after the colon. (e.g., SID: 1)
# 3. LISTS: Use a hyphen (-) to define multiple modules in a sequence.
# 4. ARRAYS: Use square brackets [ ] for channel settings (CID, PID, etc.).
# 5. COMMENTS: Anything after '#' is ignored by the program.
# 6. QUOTES: Use " " for logic strings like TLT to avoid parsing errors.
# =============================================================================
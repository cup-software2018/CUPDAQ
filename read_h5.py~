import sys
import h5py

def print_item(name, obj):
    if isinstance(obj, h5py.Dataset):
        print(f"[DSET] {name} shape={obj.shape} dtype={obj.dtype}")
        if obj.dtype.names:
            print(f"       fields={obj.dtype.names}")
    elif isinstance(obj, h5py.Group):
        print(f"[GRP ] {name}")

def preview_dataset(ds, max_rows=3):
    print(f"\n--- preview: {ds.name} ---")
    print(f"shape={ds.shape}, dtype={ds.dtype}")
    if ds.dtype.names:
        print(f"fields={ds.dtype.names}")
    try:
        n = min(max_rows, ds.shape[0]) if len(ds.shape) > 0 else 1
        data = ds[()] if len(ds.shape) == 0 else ds[:n]
        print(data)
    except Exception as e:
        print(f"preview failed: {e}")

def main(path):
    with h5py.File(path, "r") as f:
        print(f"opened: {path}\n")
        f.visititems(print_item)

        print("\n=== top-level keys ===")
        for k in f.keys():
            print(k)

        if "subrun" in f:
            preview_dataset(f["subrun"])

        # 흔히 있을 법한 이름들 후보
        candidates = [
            "event",
            "events",
            "eventinfo",
            "event_info",
            "channel",
            "channels",
            "waveform",
            "waveforms",
            "ch",
            "evt",
        ]

        for name in candidates:
            if name in f:
                preview_dataset(f[name])

        # top-level dataset 전부 조금씩 미리보기
        print("\n=== dataset previews ===")
        for k in f.keys():
            obj = f[k]
            if isinstance(obj, h5py.Dataset):
                preview_dataset(obj)

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("usage: python read_h5.py <file.h5>")
        sys.exit(1)
    main(sys.argv[1])
